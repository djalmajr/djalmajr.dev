---
import type { GetStaticPaths } from "astro";
import { NonDefaultLocales } from "@/i18n/locales";
import SearchPage from "@/pages/search.astro";

export const getStaticPaths = (() =>
  NonDefaultLocales.map(locale => ({
    params: { locale },
  }))) satisfies GetStaticPaths;
---

<SearchPage />
